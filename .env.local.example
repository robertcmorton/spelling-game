# Copy this file to .env.local and fill in your Gemini API key.
# .env.local is gitignored so the key never gets committed.
#
# Get a key from https://aistudio.google.com → "Get API key".
#
# This is only used by scripts/generate-audio.js (locally on your machine).
# The deployed app uses the GEMINI_API_KEY env var set in Vercel dashboard.

GEMINI_API_KEY=
